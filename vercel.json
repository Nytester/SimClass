{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    {
      "src": "simclass-ui/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/simclass-ui/$1" }
  ]
}
